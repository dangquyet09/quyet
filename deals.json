(async () => {
  const AFF_ID = '17310760448', SUB = 'flashsale';
  const myAff = u => 'https://s.shopee.vn/an_redir?origin_link=' + encodeURIComponent(u) + '&affiliate_id=' + AFF_ID + '&sub_id=' + SUB;
  const h = { 'x-api-source': 'pc', 'x-shopee-language': 'vi' };

  const s = await fetch('/api/v4/flash_sale/get_all_sessions?category_personalization_type=0', { headers: h }).then(r => r.json());
  const ss = (s.data && s.data.sessions) || []; const now = Math.floor(Date.now() / 1000);
  const ses = ss.find(x => x.start_time <= now && now < x.end_time) || ss[0]; const pid = ses.promotionid;

  const map = {}; let offset = 0;
  while (offset <= 600) {
    const d = await fetch('/api/v4/flash_sale/flash_sale_get_items?category_id=0&limit=30&offset=' + offset + '&promotionid=' + pid + '&sort_soldout=true&with_dp_items=true', { headers: h }).then(r => r.json());
    const batch = (d.data && d.data.items) || [];
    if (!batch.length) break;
    let added = 0;
    batch.forEach(it => { if (it.itemid && !map[it.itemid]) { map[it.itemid] = it; added++; } });
    if (!added) break;            // không có item mới -> dừng (hết hàng thật)
    offset += batch.length;
  }
  const items = Object.values(map);

  const products = items.filter(it => !it.is_soldout).map(it => {
    const p = (it.price_before_discount || 0) / 100000, f = (it.price || 0) / 100000;
    const rate = it.raw_discount || (p ? Math.round((1 - f / p) * 100) : 0);
    const url = 'https://shopee.vn/product/' + it.shopid + '/' + it.itemid;
    return { title: it.name, image: 'https://cf.shopee.vn/file/' + it.image, link: myAff(url), price: Math.round(p), final: Math.round(f), rate };
  }).sort((a, b) => b.rate - a.rate);

  const json = JSON.stringify({ products }, null, 2);
  console.log('✅ ' + products.length + ' deal (đã lọc trùng)');
  console.log(json);
  try { copy(json); console.log('📋 Đã copy — dán đè vào deals.json'); } catch (e) {}
})();
